# LeverageOS environment template
# Copy these values into .env.local for local development
# or set them in your Render dashboard.

# Required: provider API key used by the OpenAI SDK.
# For Groq, use a key that starts with gsk_.
OPENAI_API_KEY=your-provider-api-key

# Optional: OpenAI-compatible base URL.
# Leave unset for OpenAI, or point it at Groq:
# https://api.groq.com/openai/v1
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Optional: override the chat model.
# Groq example: llama-3.3-70b-versatile
# OpenAI example: gpt-4o-mini
OPENAI_MODEL=llama-3.3-70b-versatile

# Optional: GitHub token for higher public API rate limits.
# Public-repo access is enough for profile reads.
GITHUB_TOKEN=github_pat_your_token_here

# Optional: set to false to force static opportunity fallbacks.
USE_WEB_SEARCH=true
